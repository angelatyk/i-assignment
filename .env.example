# LLM Provider Configuration
# Supported: google, anthropic
LLM_PROVIDER=google
LLM_MODEL=gemini-2.5-flash
# Model used by the offline extraction script — Pro is recommended for accurate code comprehension
MEDPLUM_INDEX_MODEL=gemini-2.5-pro

# API Keys
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Medplum Repository
# Absolute or relative path to the local Medplum repo clone
MEDPLUM_REPO_PATH=./medplum
